<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:FeaturamaTester.Views"
       x:Class="FeaturamaTester.AppShell"
       Title="Featurama Tester">

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="{OnPlatform Android=ic_home, iOS=house.fill, MacCatalyst=house.fill}"
            ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent
            Title="Settings"
            Icon="{OnPlatform Android=ic_settings, iOS=gearshape.fill, MacCatalyst=gearshape.fill}"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>

</Shell>
