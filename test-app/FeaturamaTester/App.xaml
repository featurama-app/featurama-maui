<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:FeaturamaTester.Converters"
             x:Class="FeaturamaTester.App">
    <Application.Resources>
        <ResourceDictionary>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />

            <Color x:Key="Primary">#6750A4</Color>
            <Color x:Key="PrimaryDark">#381E72</Color>
            <Color x:Key="Accent">#625B71</Color>
            <Color x:Key="StatusRequested">#2196F3</Color>
            <Color x:Key="StatusRoadmap">#9C27B0</Color>
            <Color x:Key="StatusInProgress">#FF9800</Color>
            <Color x:Key="StatusDone">#4CAF50</Color>
            <Color x:Key="StatusDeclined">#F44336</Color>

            <Style TargetType="Page" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#1C1B1F}" />
            </Style>

            <Style TargetType="Shell" ApplyToDerivedTypes="True">
                <Setter Property="Shell.BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.ForegroundColor" Value="White" />
                <Setter Property="Shell.TitleColor" Value="White" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light=White, Dark=#1C1B1F}" />
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light=#999999, Dark=#666666}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
