<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FeaturamaTester.Views.HomePage"
             Title="Featurama Tester">
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="20">
        <Label Text="Tap below to open the Featurama UI" HorizontalTextAlignment="Center" />
        <Button Text="Open Feature Requests" Clicked="OnOpenFeaturama" />
        <Button Text="Settings" Clicked="OnOpenSettings" />
    </VerticalStackLayout>
</ContentPage>
